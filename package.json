{
  "name": "test-design-studio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "format": "prettier --write \"*.{js,json,ts,tsx,css,html,md,yml,yaml}\" \"src/**/*.{ts,tsx,css}\" \".github/**/*.{md,yml,yaml}\"",
    "format:check": "prettier --check \"*.{js,json,ts,tsx,css,html,md,yml,yaml}\" \"src/**/*.{ts,tsx,css}\" \".github/**/*.{md,yml,yaml}\"",
    "preview": "vite preview",
    "test": "vitest run",
    "check": "npm run lint && npm run format:check && npm run typecheck && npm run test"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^27.3.0",
    "prettier": "^3.7.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.9"
  }
}
